# Copy this file to .env.local and fill in real values.
# Never commit .env.local. It is already in .gitignore.

# --- Supabase ---
# Project Settings -> API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: server-only, bypasses RLS. Used for webhooks/admin
# operations. NEVER prefix with NEXT_PUBLIC_, never send to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Paystack (Phase 7) ---
# Test keys first, swap to live keys only at launch
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
# Register this webhook URL in your Paystack dashboard:
#   Settings -> Webhooks -> https://nimasrepub.com.ng/api/paystack/webhook

# --- Resend (email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@nimasrepub.com.ng
# Supabase Auth confirmation/recovery/invite emails are sent by Supabase.
# Configure Supabase Auth SMTP with Resend in the Supabase dashboard.

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://nimasrepub.com.ng
# Email address that receives new-submission alerts
EDITORIAL_EMAIL=editorial@nimasrepub.com.ng
